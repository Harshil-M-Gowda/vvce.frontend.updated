# ── VVCE Events Hub Frontend — Environment Variables ──────────────────────────
# Copy this to .env for local dev, or set these in Netlify → Site settings → Environment variables

# URL of your deployed backend API (no trailing slash)
# Local dev:   http://localhost:5000/api
# Production:  https://your-backend.onrender.com/api
VITE_API_URL=http://localhost:5000/api
